generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  slug         String?  @unique
  email        String   @unique
  passwordHash String
  bio          String?
  avatarUrl    String?
  hideViolentFeed Boolean @default(false)
  isPage       Boolean  @default(false)
  managedById  String?
  createdAt    DateTime @default(now())

  // User tag filter preferences: mode = "whitelist" | "blacklist" | null
  tagFilterMode String?
  // JSON array (string) of tag ids the user selected for filtering
  tagFilterTags String?

  managedBy          User?               @relation("ManagedPages", fields: [managedById], references: [id])
  managedPages       User[]              @relation("ManagedPages")
  feedSource         FeedSource?
  posts              Post[]
  likes              PostLike[]
  comments           Comment[]
  following          Connection[]        @relation("follower")
  followers          Connection[]        @relation("following")
  steelmanRequests   SteelmanRequest[]   @relation("requester")
  steelmanTargets    SteelmanRequest[]   @relation("target")
  communityMemberships CommunityMember[]
  ownedCommunities   Community[]
  hiddenPosts        HiddenPost[]
  bookmarkedPosts    BookmarkedPost[]
  feedGroups         FeedGroup[]
  childSafetyReports ChildSafetyReport[] @relation("ChildSafetyReporter")
}

model Post {
  id                 String   @id @default(cuid())
  authorId           String
  permalinkSlug      String?
  feedSourceId       String?
  externalId         String?
  urlHash            String?
  titleHash          String?
  content            String?
  sharedUrl          String?
  sharedTitle        String?
  sharedDescription  String?
  sharedSource       String?
  sharedImageUrl     String?
  imageUrls          String?
  sharedPostId       String?
  communityId        String?
  score              Float    @default(0)
  freshnessScore     Float    @default(0)
  sourceScore        Float    @default(0)
  engagementScore    Float    @default(0)
  moderationStatus   String   @default("visible")
  moderationReason   String?
  moderationExplanation String?
  moderatedAt        DateTime?
  mayContainViolence Boolean  @default(false)
  isFeedVisible      Boolean  @default(true)
  fetchedAt          DateTime @default(now())
  lastScoredAt       DateTime?
  createdAt          DateTime @default(now())

  author     User              @relation(fields: [authorId], references: [id])
  feedSource FeedSource?       @relation(fields: [feedSourceId], references: [id])
  sharedPost Post?             @relation("PostShares", fields: [sharedPostId], references: [id], onDelete: SetNull)
  sharedBy   Post[]            @relation("PostShares")
  community  Community?        @relation(fields: [communityId], references: [id])
  likes      PostLike[]
  comments   Comment[]
  reflections ThreadReflection[]
  steelmanRequests SteelmanRequest[]
  postTags   PostTag[]
  hiddenBy   HiddenPost[]
  bookmarkedBy BookmarkedPost[]
  childSafetyReports ChildSafetyReport[]

  @@unique([feedSourceId, externalId])
  @@unique([authorId, sharedPostId])
  @@unique([authorId, permalinkSlug])
  @@index([urlHash])
  @@index([titleHash])
  @@index([feedSourceId, isFeedVisible])
  @@index([score, createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#9CA3AF") // hex color
  // comma-separated keywords used for simple auto-classification
  keywords  String?
  // descriptive text to help AI classification; e.g., "zsidó közösség, vallás, izraeli-palesztin ügyek"
  description String?
  createdAt DateTime @default(now())

  postTags  PostTag[]
}

model PostTag {
  id     String @id @default(cuid())
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model FeedSource {
  id            String   @id @default(cuid())
  pageId        String   @unique
  rssUrl        String   @unique
  title         String
  description   String?
  siteUrl       String?
  imageUrl      String?
  isActive      Boolean  @default(true)
  sourceWeight  Float    @default(1)
  etag          String?
  lastModified  String?
  lastFetchedAt DateTime?
  lastSuccessAt DateTime?
  fetchErrorCount Int    @default(0)
  lastStatusCode Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  page  User   @relation(fields: [pageId], references: [id])
  posts Post[]
  groupMemberships FeedGroupFeedSource[]
}

model FeedGroup {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources FeedGroupFeedSource[]

  @@unique([userId, name])
}

model FeedGroupFeedSource {
  id           String   @id @default(cuid())
  feedGroupId  String
  feedSourceId String
  createdAt    DateTime @default(now())

  feedGroup  FeedGroup  @relation(fields: [feedGroupId], references: [id], onDelete: Cascade)
  feedSource FeedSource @relation(fields: [feedSourceId], references: [id], onDelete: Cascade)

  @@unique([feedGroupId, feedSourceId])
  @@index([feedSourceId])
}

model FeedSyncState {
  id            String   @id
  nextCursor    Int      @default(0)
  lastCleanupAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  moderationStatus String   @default("visible")
  moderationReason String?
  moderationExplanation String?
  moderatedAt DateTime?
  createdAt DateTime @default(now())

  post     Post             @relation(fields: [postId], references: [id])
  author   User             @relation(fields: [authorId], references: [id])
  parent   Comment?         @relation("replies", fields: [parentId], references: [id])
  replies  Comment[]        @relation("replies")
  analysis CommentAnalysis?
}

model CommentAnalysis {
  id               String   @id @default(cuid())
  commentId        String   @unique
  positiveSignals  String   // JSON array
  negativeSignals  String   // JSON array
  neutralSignals   String   // JSON array
  explanation      String
  analyzedAt       DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id])
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower",  fields: [followerId],  references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model SteelmanRequest {
  id          String   @id @default(cuid())
  requesterId String
  targetId    String
  postId      String
  summary     String?
  status      String   @default("pending") // pending | approved | rejected
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  requester User @relation("requester", fields: [requesterId], references: [id])
  target    User @relation("target",    fields: [targetId],    references: [id])
  post      Post @relation(fields: [postId], references: [id])
}

model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false)
  ownerId     String
  createdAt   DateTime @default(now())

  owner   User              @relation(fields: [ownerId], references: [id])
  members CommunityMember[]
  posts   Post[]
}

model CommunityMember {
  id          String   @id @default(cuid())
  communityId String
  userId      String
  role        String   @default("member") // member | admin
  joinedAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId])
}

model ThreadReflection {
  id                   String   @id @default(cuid())
  postId               String
  agreementAreas       String   // JSON array of strings
  disagreementAreas    String   // JSON array of strings
  unresolvedQuestions  String   // JSON array of strings
  qualityObservations  String   // JSON array of strings
  createdAt            DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
}

model HiddenPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model BookmarkedPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model ChildSafetyReport {
  id              String   @id @default(cuid())
  reporterId      String?
  postId          String?
  targetUrl       String?
  reason          String
  details         String
  status          String   @default("open") // open | reviewing | escalated | closed
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?

  reporter User? @relation("ChildSafetyReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  post     Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}
